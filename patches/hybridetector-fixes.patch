index a9d8b51..e494984 100644
--- a/wraps/STAR_gen_index/script.py
+++ b/wraps/STAR_gen_index/script.py
@@ -9,8 +9,18 @@ from snakemake.shell import shell
 
 TOOL = "STAR"
 
-help = subprocess.Popen("grep -v '>' " + snakemake.input.gen + " | wc -m",shell=True,stdout=subprocess.PIPE).communicate()[0]
-STAR_GENOME_BASES_LOG = min(14,math.floor(math.log(float(int(help)),2)/2-1))
+# Genome length -> STAR's --genomeSAindexNbases = min(14, log2(len)/2 - 1).
+# The original counted with `grep -v '>' <file> | wc -m`, but the whole-genome input is
+# GZIPPED (the gunzip happens further down), so grep saw binary, printed "binary file
+# matches" to stderr, and wc -m returned 0 -> math.log(0) -> ValueError. It only worked
+# for the ncRNA indices, whose inputs are plain .fa. Read through the compression.
+_reader = "zcat" if snakemake.input.gen.endswith(".gz") else "cat"
+help = subprocess.Popen(_reader + " " + snakemake.input.gen + " | grep -v '>' | wc -m",
+                        shell=True, stdout=subprocess.PIPE).communicate()[0]
+_genome_len = int(help)
+if _genome_len <= 0:
+    sys.exit("could not determine genome length from " + snakemake.input.gen)
+STAR_GENOME_BASES_LOG = min(14, math.floor(math.log(float(_genome_len), 2) / 2 - 1))
 
 shell.executable("/bin/bash")
 
@@ -34,7 +44,19 @@ if IS_COMPRESSED:
 	f.close()
 	shell(command)
 
-command = TOOL+" --runMode genomeGenerate --runThreadN "+str(snakemake.threads)+" --limitGenomeGenerateRAM " + str(snakemake.resources.mem * 1000000000) +" --genomeDir "+snakemake.params.dir+" --genomeFastaFiles "+snakemake.input.gen.replace(".gz","")+ " --genomeSAindexNbases "+str(STAR_GENOME_BASES_LOG)+" >> "+snakemake.log.run+" 2>&1 "
+# DEFAULT IS 1 = DENSE = STAR's own default = what miRBench used for Manakov. Do not
+# change that default.
+#
+# A memory-starved host can export STAR_SA_SPARSE_D=2 to store every 2nd suffix, roughly
+# halving index RAM (measured on hg38: 16 GB sparse vs an OOM at 27.9 GB dense on a 31 GB
+# box). But this is NOT free: dense and sparse produce DIFFERENT alignments. Measured on
+# chr21 with real reads, dense vs sparse differed in 7286 records against a 744-record
+# run-to-run noise floor (the noise coming from --outMultimapperOrder Random). So sparsity
+# must stay an explicit opt-in for the host that cannot do better, never a default that
+# quietly follows the pipeline onto a machine with enough RAM to do it properly.
+SA_SPARSE_D = os.environ.get("STAR_SA_SPARSE_D", "1")
+
+command = TOOL+" --runMode genomeGenerate --runThreadN "+str(snakemake.threads)+" --limitGenomeGenerateRAM " + str(snakemake.resources.mem * 1000000000) +" --genomeDir "+snakemake.params.dir+" --genomeFastaFiles "+snakemake.input.gen.replace(".gz","")+ " --genomeSAindexNbases "+str(STAR_GENOME_BASES_LOG)+" --genomeSAsparseD "+SA_SPARSE_D+" >> "+snakemake.log.run+" 2>&1 "
 f = open(snakemake.log.run, 'at')
 f.write("## COMMAND: "+command+"\n")
 f.close()
